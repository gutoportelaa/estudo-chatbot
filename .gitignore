# gitignore template for LangChain products, e.g., LangGraph, LangSmith
# website: https://www.langchain.com/
# website: https://www.langchain.com/langgraph

# LangGraph
.langgraph_api/

*.png
!docs/*.png

# Python / uv (backend)
api/.venv/
api/data/
__pycache__/
*.pyc
.env
api/.env

# Node / bun (frontend)
web/node_modules/
web/dist/
web/*.tsbuildinfo
web/vite.config.js
web/vite.config.d.ts

