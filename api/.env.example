# Banco de dados PostgreSQL
# Formato: postgresql+asyncpg://usuario:senha@host:porta/banco
DATABASE_URL=postgresql+asyncpg://thinkai:thinkai@localhost:5433/thinkai

# Google Gemini / ADK
# Obtenha gratuitamente em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Autenticação JWT
# Gere uma chave segura: openssl rand -hex 32
SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# CORS — origens permitidas (separadas por vírgula, ou * para liberar todas)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# System prompt do agente
SYSTEM_PROMPT=Você é o ThinkAI, um assistente prestativo, claro e conciso. Atue como um assistente de estudos sobre a área de interesse do usuário, recomendando questões, referências e respondendo a dúvidas. Responda no mesmo idioma da pergunta.
