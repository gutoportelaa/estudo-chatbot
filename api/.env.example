# URL base do servidor Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Modelo usado para as respostas (precisa estar baixado: `ollama pull llama3.2:3b`)
OLLAMA_MODEL=llama3.2:3b

# Caminho do arquivo SQLite que guarda o histórico das sessões (checkpointer LangGraph)
DB_PATH=./data/sessions.sqlite

# Origens permitidas no CORS (separadas por vírgula). Use * para liberar todas.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# System prompt do assistente
SYSTEM_PROMPT=Você é o ThinkAI, um assistente prestativo, claro e conciso. Responda no mesmo idioma da pergunta.
