# Variáveis de ambiente para o docker-compose.
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# Banco de dados (usado localmente fora do docker-compose)
DATABASE_URL=postgresql+asyncpg://thinkai:thinkai@localhost:5432/thinkai

# Google Gemini / ADK
# Obtenha gratuitamente em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Autenticação JWT
# Gere uma chave segura: openssl rand -hex 32
SECRET_KEY=change-me-in-production
