# Variáveis de ambiente para o docker-compose.
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# Banco de dados
DB_PASSWORD=senha_segura

# Provedor LLM: gemini | groq | openrouter | ollama
LLM_PROVIDER=groq
LLM_MODEL=

# Orquestrador: USE_ADK=true força o caminho ADK (Runner) via LiteLLM mesmo para
# provedores não-Gemini (ex.: Ollama local). Necessário p/ testar a compaction
# nativa do ADK sem chave Gemini. Gemini sempre usa o ADK.
USE_ADK=false

# Google Gemini (LLM_PROVIDER=gemini)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (LLM_PROVIDER=groq) — free tier generoso, sem cartão
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (LLM_PROVIDER=openrouter)
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Ollama (LLM_PROVIDER=ollama) — modelos locais, ideal para testes
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b

# ----- Gestão de histórico (janela deslizante + sumarização híbrida) -----
# hybrid (buffer recente + resumo) | window (só janela) | off
HISTORY_STRATEGY=hybrid
HISTORY_WINDOW_MESSAGES=12
HISTORY_SUMMARIZE_AFTER_MESSAGES=6
HISTORY_SUMMARY_MAX_TOKENS=600
# Modelo do resumidor (vazio = mesmo modelo do chat)
SUMMARIZER_MODEL=

# Context Compaction nativo do ADK (caminho Gemini; desativado por padrão)
ADK_COMPACTION_ENABLED=false

# Autenticação JWT
# Gere uma chave segura: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# URL pública da API (usado no build do frontend)
# Em produção: http://<IP_PUBLICO_EC2>:8000
# Em desenvolvimento local: http://localhost:8000
VITE_API_URL=http://localhost:8000
