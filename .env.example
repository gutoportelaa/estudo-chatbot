# Variáveis de ambiente para o docker-compose.
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# Banco de dados
DB_PASSWORD=senha_segura

# Google Gemini / ADK
# Obtenha gratuitamente em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Autenticação JWT
# Gere uma chave segura: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# URL pública da API (usado no build do frontend)
# Em produção: http://<IP_PUBLICO_EC2>:8000
# Em desenvolvimento local: http://localhost:8000
VITE_API_URL=http://localhost:8000
